<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>home - Tipix</title>
    <link rel="icon" type="image/png" href="/img/logo.svg">
    <link rel="stylesheet" href="/CSS/main.css">

</head>
<body>
    <%- include('blocks/header.ejs') %>
    <main>
     
      <section id="root">
        <h1>&gt; projects</h1>
        <p>all our projects are here</p>
      </section>

      <section id="projects">
        <h2>&gt; Projects</h2>

        <div class="container">

          <div class="block">
